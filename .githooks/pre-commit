#!/usr/bin/env bash
# Activate this hook once per clone:   git config core.hooksPath .githooks
#
# When a commit touches the `tinypress-cli` sources we regenerate
# MANUAL.md from the live `--help` output so the manual cannot drift.
# CI runs the same script with `--check` as a safety net for anyone
# bypassing the hook.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Bail early when no CLI source is staged — keeps unrelated commits
# fast (swift build is incremental but still adds ~1s).
if ! git diff --cached --name-only --diff-filter=ACMR \
        | grep -q '^core/Sources/tinypress-cli/'; then
    exit 0
fi

# Prefer a real Xcode toolchain when only CommandLineTools is selected;
# the `swift build` inside the script needs swift-tools-version 6.2.
if [ -z "${DEVELOPER_DIR:-}" ]; then
    for xc in /Applications/Xcode-26*.app /Applications/Xcode.app; do
        if [ -d "$xc/Contents/Developer" ]; then
            export DEVELOPER_DIR="$xc/Contents/Developer"
            break
        fi
    done
fi

python3 core/scripts/generate-manual.py
git add core/MANUAL.md
